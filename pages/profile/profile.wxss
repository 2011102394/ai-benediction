/** 个人中心页面样式 **/

.container {
  padding: 20rpx 30rpx 60rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8F0 0%, #f7f7f7 100%);
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #D32F2F 0%, #FF6B6B 50%, #FF8A80 100%);
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  box-shadow: 0 12rpx 40rpx rgba(211, 47, 47, 0.25);
  position: relative;
  overflow: hidden;
}

.user-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  background: rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(255,255,255,0.3), rgba(255,255,255,0.1));
}

.avatar-icon {
  font-size: 72rpx;
  opacity: 0.9;
}

.user-info {
  flex: 1;
  color: #fff;
  position: relative;
  z-index: 1;
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.user-status {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.login-badge {
  width: 56rpx;
  height: 56rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  border: 4rpx solid rgba(255,255,255,0.3);
}

.edit-arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.6);
  margin-left: 20rpx;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #D32F2F;
  margin-bottom: 8rpx;
}

.stats-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.stats-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.stats-hint {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

/* 登录按钮 - 放在action-list底部 */
.login-btn-main {
  width: 100% !important;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding: 0;
  height: 88rpx;
  background: linear-gradient(135deg, #D32F2F, #FF6B6B);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 16rpx rgba(211, 47, 47, 0.3);
  border: none;
  line-height: 1;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.login-btn-main::after {
  border: none;
}

.login-btn-main:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(211, 47, 47, 0.2);
}

/* action-item支持多行内容 */
.action-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.action-desc {
  font-size: 26rpx;
  color: #999;
}

/* 特权列表项 - 移除箭头 */
.action-item.privilege-item .action-arrow {
  display: none;
}

/* 最后一个特权项不显示分隔线 */
.action-item.privilege-item.last-privilege::before {
  display: none;
}

/* 功能列表 */
.action-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.action-item,
button.action-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  line-height: 1.5;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  font-size: inherit;
  color: inherit;
  font-weight: normal;
}

/* 使用伪元素创建分隔线，避免border被覆盖 */
.action-item::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 2rpx;
  background: #f5f5f5;
}

.action-item:last-child::before {
  display: none;
}

.action-item::after {
  border: none;
}

.action-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  width: 40rpx;
  text-align: center;
}

.action-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.action-arrow {
  font-size: 36rpx;
  color: #ccc;
  flex-shrink: 0;
  margin-left: 20rpx;
}

/* 完善资料提示 */
.complete-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
  border-radius: 20rpx;
  border: 2rpx solid #ffcc80;
}

.tip-text {
  font-size: 30rpx;
  color: #e65100;
}

.tip-arrow {
  font-size: 36rpx;
  color: #e65100;
}

/* 调试区域 */
.debug-section {
  margin-top: 40rpx;
  padding: 20rpx;
}

.debug-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.debug-btn {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: 2rpx solid #ddd;
  line-height: 1.5;
}

.debug-btn::after {
  border: none;
}

.debug-btn:active {
  background: #eee;
}
