<view class="container">
  <!-- 表单卡片 -->
  <view class="form-card">
    <!-- 头像行 - 使用官方推荐的 chooseAvatar 按钮 -->
    <button class="edit-row avatar-row" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <text class="row-label">头像</text>
      <view class="row-value">
        <image wx:if="{{tempAvatarUrl}}" class="row-avatar" src="{{tempAvatarUrl}}" mode="aspectFill" />
        <view wx:else class="row-avatar-empty">
          <text>👤</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </button>

    <!-- 昵称行 -->
    <view class="edit-row nickname-row">
      <text class="row-label">昵称</text>
      <input 
        type="nickname" 
        class="nickname-input" 
        placeholder="请输入昵称（可选）"
        value="{{tempNickName}}"
        bind:input="onNickNameInput"
      />
    </view>
  </view>


  <!-- 确定按钮 -->
  <button class="confirm-btn" bindtap="saveProfile">
    确定
  </button>
</view>
