<view class="container">
  <!-- 头像行 -->
  <view class="edit-row" bindtap="chooseAvatar">
    <text class="row-label">头像</text>
    <view class="row-value">
      <image wx:if="{{tempAvatarUrl}}" class="row-avatar" src="{{tempAvatarUrl}}" mode="aspectFill" />
      <view wx:else class="row-avatar-empty">
        <text>👤</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 昵称行 -->
  <view class="edit-row nickname-row">
    <text class="row-label">昵称</text>
    <input 
      type="nickname" 
      class="nickname-input" 
      placeholder="请输入昵称（可选）"
      value="{{tempNickName}}"
      bind:input="onNickNameInput"
    />
  </view>

  <!-- 提示 -->
  <view class="edit-hint">不填写将显示默认昵称</view>

  <!-- 确定按钮 -->
  <button class="confirm-btn active" bindtap="saveProfile">
    确定
  </button>
</view>

<!-- 头像选择弹窗 -->
<view class="avatar-popup {{showAvatarPopup ? 'show' : ''}}" bindtap="hideAvatarPopup">
  <view class="popup-mask"></view>
  <view class="popup-content" catchtap="stopPropagation">
    <view class="popup-title">用微信头像</view>
    <button class="popup-item" open-type="chooseAvatar" bind:chooseavatar="onChooseWxAvatar">
      <image class="wx-avatar" src="{{wxAvatarUrl}}" mode="aspectFill" wx:if="{{wxAvatarUrl}}" />
      <text wx:else>使用默认头像</text>
    </button>
    <view class="popup-divider"></view>
    <view class="popup-item" bindtap="chooseFromAlbum">
      <text>从相册选择</text>
    </view>
    <view class="popup-item" bindtap="takePhoto">
      <text>拍照</text>
    </view>
    <view class="popup-cancel" bindtap="hideAvatarPopup">
      <text>取消</text>
    </view>
  </view>
</view>
