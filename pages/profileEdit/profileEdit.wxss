/** 个人信息编辑页面样式 **/

page {
  background: #f5f5f5;
}

.container {
  padding: 30rpx;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 编辑行 - 基础样式 */
.edit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 120rpx;
  padding: 0 30rpx;
  background: #fff;
  border-bottom: 2rpx solid #f5f5f5;
  box-sizing: border-box;
}

.edit-row:last-child {
  border-bottom: none;
}

/* 头像行 - 微信官方推荐的 chooseAvatar 按钮样式 */
.avatar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100vw !important;
  margin: 0;
  height: 120rpx;
  background: #fff;
  border: none;
  border-radius: 0;
  line-height: 1;
  font-size: inherit;
  color: inherit;
  text-align: left;
  box-sizing: border-box;
}

.avatar-row::after {
  border: none;
}

.row-label {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.row-value {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.row-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  margin-right:30rpx;
}

.row-avatar-empty {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 8rpx;
}

/* 昵称输入框 */
.nickname-input {
  flex: 1;
  height: 72rpx;
  font-size: 32rpx;
  color: #333;
  text-align: right;
  margin-left: 40rpx;
}

.nickname-input::placeholder {
  color: #bbb;
}

/* 提示文字 */
.edit-hint {
  padding: 24rpx 30rpx;
  font-size: 26rpx;
  color: #999;
}

/* 确定按钮 */
.confirm-btn {
  width: 100% !important;
  margin: 60rpx 0 30rpx;
  height: 96rpx;
   background: linear-gradient(135deg, #D32F2F 0%, #FF6B6B 50%, #FF8A80 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(236, 64, 122, 0.35);
  transition: all 0.3s ease;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(236, 64, 122, 0.25);
}


