<view class="container">
  <!-- 筛选标签 -->
  <view class="filter-container">
    <view class="filter-content">
      <view class="filter-tabs">
        <view class="filter-tab {{filterType === 'all' ? 'active' : ''}}" data-type="all" bindtap="switchFilter">
          <view class="tab-content">
            <text>全部</text>
            <text class="filter-count">({{totalCount}})</text>
          </view>
          <view class="tab-indicator" wx:if="{{filterType === 'all'}}"></view>
        </view>
        <view class="filter-tab {{filterType === 'blessing' ? 'active' : ''}}" data-type="blessing" bindtap="switchFilter">
          <view class="tab-content">
            <text>祝福语</text>
            <text class="filter-count">({{blessingCount}})</text>
          </view>
          <view class="tab-indicator" wx:if="{{filterType === 'blessing'}}"></view>
        </view>
        <view class="filter-tab {{filterType === 'reply' ? 'active' : ''}}" data-type="reply" bindtap="switchFilter">
          <view class="tab-content">
            <text>回复语</text>
            <text class="filter-count">({{replyCount}})</text>
          </view>
          <view class="tab-indicator" wx:if="{{filterType === 'reply'}}"></view>
        </view>
      </view>
      <view class="filter-actions" wx:if="{{totalCount > 0}}">
        <view class="clear-btn" bindtap="clearHistory">
          <text class="clear-icon">🗑️</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 历史列表 -->
  <view class="history-list" wx:if="{{filteredList.length > 0}}">
    <view class="history-item" wx:for="{{filteredList}}" wx:key="id">
      <!-- 标签区域 -->
      <view class="item-tags-section">
        <view class="tag-row">
          <view class="tags-left">
            <text class="tag {{item.type === 'blessing' ? 'tag-blessing' : 'tag-reply'}}">{{item.type === 'blessing' ? '祝福语' : '回复语'}}</text>
            <text class="tag tag-festival">{{item.festival}}</text>
            <text class="tag tag-recipient">{{item.recipient}}</text>
          </view>
          <view class="expand-btn-wrapper">
            <view class="expand-btn" bindtap="toggleExpand" data-index="{{index}}" wx:if="{{item.content && item.content.length > 80}}">
              <text>{{item.isExpanded ? '收起' : '展开'}}</text>
              <text>{{item.isExpanded ? '▲' : '▼'}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 内容区域 -->
      <view class="item-content-section">
        <view class="item-content {{item.isExpanded ? 'expanded' : ''}}">
          {{item.content}}
        </view>
      </view>
      
      <!-- 操作区域 -->
      <view class="item-actions">
        <view class="actions-right">
          <text class="item-time">{{item.formattedTime}}</text>
          <view class="actions-buttons">
            <view class="action-btn" bindtap="copyContent" data-content="{{item.content}}">
              <text>📋</text>
              <text>复制</text>
            </view>
            <view class="action-btn delete" bindtap="deleteItem" data-id="{{item._id}}">
              <text>🗑️</text>
              <text>删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredList.length === 0}}">
    <view class="empty-icon">📝</view>
    <text class="empty-text">暂无历史记录</text>
    <text class="empty-subtext">生成祝福语或回复语后将自动保存到这里</text>
  </view>
</view>
