<view class="container">
  <!-- 节日选择 -->
  <view class="card">
    <view class="card-title">
      <view class="card-title-icon" style="background: {{styles.gradient || 'linear-gradient(180deg, #D32F2F, #FF6B6B)'}}"></view>
      <text>选择节日</text>
    </view>
    <!-- 加载中 -->
    <view class="loading-small" wx:if="{{festivals.length === 0}}">
      <text>加载中...</text>
    </view>
    <scroll-view class="selector-scroll" scroll-y enhanced show-scrollbar="{{false}}" wx:else>
      <view class="selector-grid">
        <view 
          class="selector-item {{selectedFestival === item.id ? 'active' : ''}}"
          wx:for="{{festivals}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          data-theme="{{item.theme}}"
          bindtap="selectFestival"
        >
          <text class="item-icon">{{item.icon}}</text>
          <text class="item-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 回复对象选择 -->
  <view class="card">
    <view class="card-title">
      <view class="card-title-icon" style="background: {{styles.gradient || 'linear-gradient(180deg, #D32F2F, #FF6B6B)'}}"></view>
      <text>回复对象</text>
    </view>
    <!-- 加载中 -->
    <view class="loading-small" wx:if="{{recipients.length === 0}}">
      <text>加载中...</text>
    </view>
    <scroll-view class="selector-scroll" scroll-y enhanced show-scrollbar="{{false}}" wx:else>
      <view class="selector-grid">
        <view 
          class="selector-item {{selectedRecipient === item.id ? 'active' : ''}}"
          wx:for="{{recipients}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          bindtap="selectRecipient"
        >
          <text class="item-icon">{{item.icon}}</text>
          <text class="item-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 收到的祝福语输入 -->
  <view class="card">
    <view class="card-title">
      <view class="card-title-icon" style="background: {{styles.gradient || 'linear-gradient(180deg, #D32F2F, #FF6B6B)'}}"></view>
      <text>收到的祝福语</text>
    </view>
    <textarea 
      class="blessing-input"
      placeholder="请粘贴您收到的祝福语，AI将为您生成得体的回复..."
      value="{{receivedBlessing}}"
      bindinput="onReceivedBlessingInput"
      maxlength="500"
    />
  </view>

  <!-- 生成结果 -->
  <view class="result-card" wx:if="{{generatedReply}}">
    <view class="result-text">{{generatedReply}}</view>
    <view class="result-actions">
      <view class="action-btn copy" bindtap="copyReply">
        <text>📋</text>
        <text>复制</text>
      </view>
    </view>
  </view>

  <!-- 生成按钮（仅在次数未用完时显示） -->
  <button 
    wx:if="{{usageInfo.type !== 'need_login' && usageInfo.type !== 'need_invite'}}"
    class="generate-btn {{!canGenerate ? 'disabled' : ''}}"
    bindtap="generateReply"
    disabled="{{!canGenerate || loading}}"
  >
    <text wx:if="{{!loading}}">💬 生成回复语</text>
    <text wx:else>生成中...</text>
  </button>

  <!-- 使用次数提示（仅在未显示限制卡片时显示） -->
  <view class="usage-hint" wx:if="{{usageInfo.type !== 'need_login' && usageInfo.type !== 'need_invite'}}">
    <text>{{usageInfo.message || '今日可用5次'}}</text>
    <text wx:if="{{usageInfo.inviteRemaining > 0}}" class="invite-count">（邀请奖励: {{usageInfo.inviteRemaining}}次）</text>
  </view>

  <!-- 免费次数用完提示 - 登录引导 -->
  <view class="limit-card" wx:if="{{usageInfo.type === 'need_login'}}">
    <view class="limit-title">⚠️ 免费次数已用完</view>
    
    <view class="limit-item">
      <text class="limit-icon">✨</text>
      <view class="limit-content">
        <text class="limit-text">更多免费次数</text>
        <text class="limit-desc">每天10次（游客仅5次）</text>
      </view>
    </view>
    
    <view class="limit-item">
      <text class="limit-icon">🎁</text>
      <view class="limit-content">
        <text class="limit-text">邀请奖励</text>
        <text class="limit-desc">每邀请1人各得2次（永久有效）</text>
      </view>
    </view>
    
    <view class="limit-item">
      <text class="limit-icon">📝</text>
      <view class="limit-content">
        <text class="limit-text">自定义内容</text>
        <text class="limit-desc">可添加专属节日和祝福对象</text>
      </view>
    </view>
    
    <view class="limit-item last-item">
      <text class="limit-icon">☁️</text>
      <view class="limit-content">
        <text class="limit-text">云端同步</text>
        <text class="limit-desc">数据保存，换设备不丢失</text>
      </view>
    </view>
    
    <button class="limit-btn" bindtap="handleLogin">微信一键登录</button>
  </view>

  <!-- 免费次数用完提示 - 邀请引导 -->
  <view class="limit-card" wx:if="{{usageInfo.type === 'need_invite'}}">
    <view class="limit-title">⚠️ 今日免费次数已用完</view>
    
    <view class="limit-item">
      <text class="limit-icon">🎁</text>
      <view class="limit-content">
        <text class="limit-text">邀请好友得次数</text>
        <text class="limit-desc">每邀请1人双方各得2次（永久有效）</text>
      </view>
    </view>
    
    <view class="limit-item last-item">
      <text class="limit-icon">⏰</text>
      <view class="limit-content">
        <text class="limit-text">每日重置</text>
        <text class="limit-desc">24小时后免费次数自动恢复</text>
      </view>
    </view>
    
    <button class="limit-btn invite" open-type="share">邀请好友获取次数</button>
  </view>

  <!-- 加载动画 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-icon">💬</view>
    <text class="loading-text">AI正在思考回复...</text>
  </view>
</view>
