/** 回复语页面样式 **/

.container {
  padding: 20rpx 30rpx 60rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8F0 0%, #f7f7f7 100%);
}

/* 输入框样式 */
.blessing-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 选择器滚动容器 - 最多显示3行 */
.selector-scroll {
  max-height: 510rpx;
}

/* 网格选择器 - 每行4个 */
.selector-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 4rpx 0;
}

.selector-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  background: #f5f5f5;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.selector-item.active {
  box-shadow: 0 4rpx 12rpx rgba(211, 47, 47, 0.3);
}

.selector-item .item-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.selector-item .item-name {
  font-size: 26rpx;
  color: #666;
}

.selector-item.active .item-name {
  color: #fff;
}

.result-card {
  background: linear-gradient(135deg, #fff9f9, #ffffff);
  border: 2rpx solid rgba(211, 47, 47, 0.15);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-top: 30rpx;
  position: relative;
}

.result-card::before {
  content: '"';
  position: absolute;
  top: 20rpx;
  left: 30rpx;
  font-size: 60rpx;
  color: rgba(211, 47, 47, 0.2);
  font-family: Georgia, serif;
}

.result-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  padding-left: 20rpx;
}

.loading-small {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.loading-icon {
  font-size: 60rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.7; }
}

/* 登录引导区域 */
.login-section {
  margin: 20rpx 0;
  padding: 30rpx;
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  border: 2rpx solid #64B5F6;
  border-radius: 16rpx;
  text-align: center;
}

.login-hint {
  font-size: 28rpx;
  color: #1565C0;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 24rpx;
  color: #1976D2;
  margin-bottom: 24rpx;
}

.login-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #2196F3, #1565C0);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.3);
  border: none;
  line-height: 1.5;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(33, 150, 243, 0.3);
}

/* 邀请好友区域 */
.invite-section {
  margin: 20rpx 0;
  padding: 30rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border: 2rpx solid #81C784;
  border-radius: 16rpx;
  text-align: center;
}

.invite-hint {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.invite-desc {
  font-size: 24rpx;
  color: #558B2F;
  margin-bottom: 24rpx;
}

.invite-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #43A047, #2E7D32);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(67, 160, 71, 0.3);
  border: none;
  line-height: 1.5;
}

.invite-btn::after {
  border: none;
}

.invite-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(67, 160, 71, 0.3);
}

/* 使用次数提示 */
.usage-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.invite-count {
  color: #43A047;
  font-weight: 500;
}
