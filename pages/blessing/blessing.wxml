<view class="container">
  <!-- 节日选择 -->
  <view class="card">
    <view class="card-title">
      <view class="card-title-icon" style="background: {{styles.gradient || 'linear-gradient(180deg, #D32F2F, #FF6B6B)'}}"></view>
      <text>选择节日</text>
    </view>
    <!-- 加载中 -->
    <view class="loading-small" wx:if="{{festivals.length === 0}}">
      <text>加载中...</text>
    </view>
    <scroll-view class="selector-scroll" scroll-y enhanced show-scrollbar="{{false}}" wx:else>
      <view class="selector-grid">
        <view 
          class="selector-item {{selectedFestival === item.id ? 'active' : ''}}"
          wx:for="{{festivals}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          data-theme="{{item.theme}}"
          bindtap="selectFestival"
        >
          <text class="item-icon">{{item.icon}}</text>
          <text class="item-name">{{item.name}}</text>
        </view>
        <!-- 添加自定义节日按钮 - 仅登录用户显示 -->
        <view class="selector-item add-btn" bindtap="showAddFestivalInput" wx:if="{{isLogin}}">
          <text class="item-icon">➕</text>
          <text class="item-name">添加</text>
        </view>
      </view>
    </scroll-view>
    
  </view>

  <!-- 祝福对象选择 -->
  <view class="card">
    <view class="card-title">
      <view class="card-title-icon" style="background: {{styles.gradient || 'linear-gradient(180deg, #D32F2F, #FF6B6B)'}}"></view>
      <text>选择祝福对象</text>
    </view>
    <!-- 加载中 -->
    <view class="loading-small" wx:if="{{recipients.length === 0}}">
      <text>加载中...</text>
    </view>
    <scroll-view class="selector-scroll" scroll-y enhanced show-scrollbar="{{false}}" wx:else>
      <view class="selector-grid">
        <view 
          class="selector-item {{selectedRecipient === item.id ? 'active' : ''}}"
          wx:for="{{recipients}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          bindtap="selectRecipient"
        >
          <text class="item-icon">{{item.icon}}</text>
          <text class="item-name">{{item.name}}</text>
        </view>
        <!-- 添加自定义对象按钮 - 仅登录用户显示 -->
        <view class="selector-item add-btn" bindtap="showAddRecipientInput" wx:if="{{isLogin}}">
          <text class="item-icon">➕</text>
          <text class="item-name">添加</text>
        </view>
      </view>
    </scroll-view>
    
  </view>

  <!-- 生成结果 -->
  <view class="result-card" wx:if="{{generatedBlessing}}">
    <view class="result-text">{{generatedBlessing}}</view>
    <view class="result-actions">
      <view class="action-btn copy" bindtap="copyBlessing">
        <text>📋</text>
        <text>复制</text>
      </view>
    </view>
  </view>

  <!-- 生成按钮（仅在次数未用完时显示） -->
  <button 
    wx:if="{{usageInfo.type !== 'need_login' && usageInfo.type !== 'need_invite'}}"
    class="generate-btn {{!canGenerate ? 'disabled' : ''}}"
    bindtap="generateBlessing"
    disabled="{{!canGenerate || loading}}"
  >
    <text wx:if="{{!loading}}">✨ 生成祝福语</text>
    <text wx:else>生成中...</text>
  </button>

  <!-- 使用次数提示（仅在未显示限制卡片时显示） -->
  <view class="usage-hint" wx:if="{{usageInfo.type !== 'need_login' && usageInfo.type !== 'need_invite'}}">
    <text>{{usageInfo.message || '今日可用5次'}}</text>
    <text wx:if="{{usageInfo.inviteRemaining > 0}}" class="invite-count">（邀请奖励: {{usageInfo.inviteRemaining}}次）</text>
  </view>

  <!-- 免费次数用完提示 - 登录引导 -->
  <view class="limit-card" wx:if="{{usageInfo.type === 'need_login'}}">
    <view class="limit-title">⚠️ 免费次数已用完</view>
    
    <view class="limit-item">
      <text class="limit-icon">✨</text>
      <view class="limit-content">
        <text class="limit-text">更多免费次数</text>
        <text class="limit-desc">每天10次（游客仅5次）</text>
      </view>
    </view>
    
    <view class="limit-item">
      <text class="limit-icon">🎁</text>
      <view class="limit-content">
        <text class="limit-text">邀请奖励</text>
        <text class="limit-desc">每邀请1人各得2次（永久有效）</text>
      </view>
    </view>
    
    <view class="limit-item">
      <text class="limit-icon">📝</text>
      <view class="limit-content">
        <text class="limit-text">自定义内容</text>
        <text class="limit-desc">可添加专属节日和祝福对象</text>
      </view>
    </view>
    
    <view class="limit-item last-item">
      <text class="limit-icon">☁️</text>
      <view class="limit-content">
        <text class="limit-text">云端同步</text>
        <text class="limit-desc">数据保存，换设备不丢失</text>
      </view>
    </view>
    
    <button class="limit-btn" bindtap="handleLogin">微信一键登录</button>
  </view>

  <!-- 免费次数用完提示 - 邀请引导 -->
  <view class="limit-card" wx:if="{{usageInfo.type === 'need_invite'}}">
    <view class="limit-title">⚠️ 今日免费次数已用完</view>
    
    <view class="limit-item">
      <text class="limit-icon">🎁</text>
      <view class="limit-content">
        <text class="limit-text">邀请好友得次数</text>
        <text class="limit-desc">每邀请1人双方各得2次（永久有效）</text>
      </view>
    </view>
    
    <view class="limit-item last-item">
      <text class="limit-icon">⏰</text>
      <view class="limit-content">
        <text class="limit-text">每日重置</text>
        <text class="limit-desc">24小时后免费次数自动恢复</text>
      </view>
    </view>
    
    <button class="limit-btn invite" open-type="share">邀请好友获取次数</button>
  </view>

  <!-- 广告相关代码（流量主开通后启用）
  <view class="ad-section" wx:if="{{usageInfo.type === 'need_ad'}}">
    <view class="ad-hint">💡 观看短视频可获得 {{usageInfo.adRemaining || 10}} 次额外机会</view>
    <view class="ad-btn" bindtap="watchAd">
      <text>🎬</text>
      <text>观看视频获取次数</text>
    </view>
  </view>
  -->

  <!-- 加载动画 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-icon">✨</view>
    <text class="loading-text">AI正在生成中...</text>
  </view>

  <!-- 自定义节日弹窗 -->
  <view class="popup-mask {{showCustomFestivalInput ? 'show' : ''}}" bindtap="hideAddFestivalInput" wx:if="{{showCustomFestivalInput || animatingFestival}}">
    <view class="popup-content {{showCustomFestivalInput ? 'show' : ''}}" catchtap="stopPropagation">
      <view class="popup-header">
        <text class="popup-title">添加自定义节日</text>
        <view class="popup-close" bindtap="hideAddFestivalInput">
          <text>✕</text>
        </view>
      </view>
      <view class="popup-body">
        <input 
          class="popup-input"
          placeholder="请输入节日名称" 
          value="{{customFestival}}"
          bindinput="onCustomFestivalInput"
          focus="{{showCustomFestivalInput}}"
        />
      </view>
      <view class="popup-footer">
        <view class="popup-btn cancel" bindtap="hideAddFestivalInput">取消</view>
        <view class="popup-btn confirm" bindtap="addCustomFestival">确认添加</view>
      </view>
    </view>
  </view>

  <!-- 自定义祝福对象弹窗 -->
  <view class="popup-mask {{showCustomRecipientInput ? 'show' : ''}}" bindtap="hideAddRecipientInput" wx:if="{{showCustomRecipientInput || animatingRecipient}}">
    <view class="popup-content {{showCustomRecipientInput ? 'show' : ''}}" catchtap="stopPropagation">
      <view class="popup-header">
        <text class="popup-title">添加自定义对象</text>
        <view class="popup-close" bindtap="hideAddRecipientInput">
          <text>✕</text>
        </view>
      </view>
      <view class="popup-body">
        <input 
          class="popup-input"
          placeholder="请输入对象名称" 
          value="{{customRecipient}}"
          bindinput="onCustomRecipientInput"
          focus="{{showCustomRecipientInput}}"
        />
      </view>
      <view class="popup-footer">
        <view class="popup-btn cancel" bindtap="hideAddRecipientInput">取消</view>
        <view class="popup-btn confirm" bindtap="addCustomRecipient">确认添加</view>
      </view>
    </view>
  </view>
</view>
