<view class="container">
  <!-- 节日选择 -->
  <view class="card">
    <view class="card-title">
      <view class="card-title-icon" style="background: {{styles.gradient || 'linear-gradient(180deg, #D32F2F, #FF6B6B)'}}"></view>
      <text>选择节日</text>
    </view>
    <!-- 加载中 -->
    <view class="loading-small" wx:if="{{festivals.length === 0}}">
      <text>加载中...</text>
    </view>
    <view class="selector" wx:else>
      <view 
        class="selector-item {{selectedFestival === item.id ? 'active' : ''}}"
        wx:for="{{festivals}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        data-theme="{{item.theme}}"
        bindtap="selectFestival"
        style="{{selectedFestival === item.id ? 'background:' + (styles.gradient || 'linear-gradient(135deg, #D32F2F, #FF6B6B)') + ';color:#fff;' : ''}}"
      >
        <text>{{item.icon}}</text>
        <text>{{item.name}}</text>
      </view>
      <!-- 添加自定义节日按钮 -->
      <view class="selector-item add-btn" bindtap="showAddFestivalInput">
        <text>➕</text>
        <text>添加</text>
      </view>
    </view>
    
    <!-- 自定义节日输入 -->
    <view class="custom-input-box" wx:if="{{showCustomFestivalInput}}">
      <view class="custom-input-header">
        <text class="custom-title">添加自定义节日</text>
        <text class="custom-close" bindtap="hideAddFestivalInput">✕</text>
      </view>
      <view class="custom-input-row">
        <input 
          class="custom-input-field"
          placeholder="输入节日名称，如：公司周年庆" 
          value="{{customFestival}}"
          bindinput="onCustomFestivalInput"
          focus="{{showCustomFestivalInput}}"
        />
        <view class="btn-add" bindtap="addCustomFestival">确认添加</view>
      </view>
    </view>
  </view>

  <!-- 祝福对象选择 -->
  <view class="card">
    <view class="card-title">
      <view class="card-title-icon" style="background: {{styles.gradient || 'linear-gradient(180deg, #D32F2F, #FF6B6B)'}}"></view>
      <text>选择祝福对象</text>
    </view>
    <!-- 加载中 -->
    <view class="loading-small" wx:if="{{recipients.length === 0}}">
      <text>加载中...</text>
    </view>
    <view class="selector" wx:else>
      <view 
        class="selector-item {{selectedRecipient === item.id ? 'active' : ''}}"
        wx:for="{{recipients}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        bindtap="selectRecipient"
        style="{{selectedRecipient === item.id ? 'background:' + (styles.gradient || 'linear-gradient(135deg, #D32F2F, #FF6B6B)') + ';color:#fff;' : ''}}"
      >
        <text>{{item.icon}}</text>
        <text>{{item.name}}</text>
      </view>
      <!-- 添加自定义对象按钮 -->
      <view class="selector-item add-btn" bindtap="showAddRecipientInput">
        <text>➕</text>
        <text>添加</text>
      </view>
    </view>
    
    <!-- 自定义对象输入 -->
    <view class="custom-input-box" wx:if="{{showCustomRecipientInput}}">
      <view class="custom-input-header">
        <text class="custom-title">添加自定义对象</text>
        <text class="custom-close" bindtap="hideAddRecipientInput">✕</text>
      </view>
      <view class="custom-input-row">
        <input 
          class="custom-input-field"
          placeholder="输入对象名称，如：合伙人" 
          value="{{customRecipient}}"
          bindinput="onCustomRecipientInput"
          focus="{{showCustomRecipientInput}}"
        />
        <view class="btn-add" bindtap="addCustomRecipient">确认添加</view>
      </view>
    </view>
  </view>

  <!-- 生成按钮 -->
  <button 
    class="generate-btn {{!canGenerate ? 'disabled' : ''}}"
    bindtap="generateBlessing"
    disabled="{{!canGenerate || loading}}"
  >
    <text wx:if="{{!loading}}">✨ 生成祝福语</text>
    <text wx:else>生成中...</text>
  </button>

  <!-- 使用次数提示 -->
  <view class="usage-hint">
    <text>{{usageInfo.message || '今日可用5次'}}</text>
    <text wx:if="{{usageInfo.inviteRemaining > 0}}" class="invite-count">（邀请奖励: {{usageInfo.inviteRemaining}}次）</text>
  </view>

  <!-- 未登录引导 -->
  <view class="login-section" wx:if="{{usageInfo.type === 'need_login'}}">
    <view class="login-hint">💡 免费次数已用完</view>
    <view class="login-desc">登录后每天可享10次免费机会，还能邀请好友获取更多次数！</view>
    <button class="login-btn" bindtap="goToLogin">
      <text>🔐</text>
      <text>立即登录获取更多次数</text>
    </button>
  </view>

  <!-- 邀请好友获取次数 -->
  <view class="invite-section" wx:if="{{usageInfo.type === 'need_invite'}}">
    <view class="invite-hint">💡 今日免费次数已用完</view>
    <view class="invite-desc">邀请好友，每邀请一人可获得2次额外机会（永久有效）</view>
    <button class="invite-btn" open-type="share">
      <text>🎁</text>
      <text>邀请好友获取次数</text>
    </button>
  </view>

  <!-- 广告相关代码（流量主开通后启用）
  <view class="ad-section" wx:if="{{usageInfo.type === 'need_ad'}}">
    <view class="ad-hint">💡 观看短视频可获得 {{usageInfo.adRemaining || 10}} 次额外机会</view>
    <view class="ad-btn" bindtap="watchAd">
      <text>🎬</text>
      <text>观看视频获取次数</text>
    </view>
  </view>
  -->

  <!-- 生成结果 -->
  <view class="result-card" wx:if="{{generatedBlessing}}">
    <view class="result-text">{{generatedBlessing}}</view>
    <view class="result-actions">
      <view class="action-btn copy" bindtap="copyBlessing">
        <text>📋</text>
        <text>复制</text>
      </view>
    </view>
  </view>

  <!-- 加载动画 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-icon">✨</view>
    <text class="loading-text">AI正在生成中...</text>
  </view>
</view>
