/** 祝福语页面样式 **/

.container {
  padding: 20rpx 30rpx 60rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8F0 0%, #f7f7f7 100%);
}

/* 选择器样式优化 */
.selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.selector-item {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.selector-item.active {
  box-shadow: 0 4rpx 12rpx rgba(211, 47, 47, 0.3);
}

/* 自定义输入框 */
.custom-input {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
}

.custom-input input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
}

.custom-input .btn-add {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #D32F2F, #FF6B6B);
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  margin-left: 16rpx;
}

/* 添加按钮样式 */
.selector-item.add-btn {
  background: #fff;
  border: 2rpx dashed #ccc;
  color: #999;
}

.selector-item.add-btn:active {
  background: #f5f5f5;
  border-color: #D32F2F;
  color: #D32F2F;
}

/* 自定义输入框样式 */
.custom-input-box {
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff9f9, #ffffff);
  border: 2rpx solid rgba(211, 47, 47, 0.2);
  border-radius: 16rpx;
}

.custom-input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.custom-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.custom-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.custom-input-row {
  display: flex;
  align-items: center;
}

.custom-input-field {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.custom-input-field:focus {
  border-color: #D32F2F;
}

/* 结果卡片特殊样式 */
.result-card {
  background: linear-gradient(135deg, #fff9f9, #ffffff);
  border: 2rpx solid rgba(211, 47, 47, 0.15);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-top: 30rpx;
  position: relative;
}

.result-card::before {
  content: '"';
  position: absolute;
  top: 20rpx;
  left: 30rpx;
  font-size: 60rpx;
  color: rgba(211, 47, 47, 0.2);
  font-family: Georgia, serif;
}

.result-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  padding-left: 20rpx;
}

/* 加载动画 */
.loading-small {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 登录引导区域 */
.login-section {
  margin: 20rpx 0;
  padding: 30rpx;
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  border: 2rpx solid #64B5F6;
  border-radius: 16rpx;
  text-align: center;
}

.login-hint {
  font-size: 28rpx;
  color: #1565C0;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 24rpx;
  color: #1976D2;
  margin-bottom: 24rpx;
}

.login-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #2196F3, #1565C0);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.3);
  border: none;
  line-height: 1.5;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(33, 150, 243, 0.3);
}

/* 邀请好友区域 */
.invite-section {
  margin: 20rpx 0;
  padding: 30rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border: 2rpx solid #81C784;
  border-radius: 16rpx;
  text-align: center;
}

.invite-hint {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.invite-desc {
  font-size: 24rpx;
  color: #558B2F;
  margin-bottom: 24rpx;
}

.invite-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #43A047, #2E7D32);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(67, 160, 71, 0.3);
  border: none;
  line-height: 1.5;
}

.invite-btn::after {
  border: none;
}

.invite-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(67, 160, 71, 0.3);
}

/* 使用次数提示 */
.usage-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.invite-count {
  color: #43A047;
  font-weight: 500;
}

