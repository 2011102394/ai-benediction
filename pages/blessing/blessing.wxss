/** 祝福语页面样式 **/

.container {
  padding: 20rpx 30rpx 60rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8F0 0%, #f7f7f7 100%);
}

/* 选择器滚动容器 - 最多显示3行 */
.selector-scroll {
  max-height: 510rpx;
}

/* 网格选择器 - 每行4个 */
.selector-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 4rpx 0;
}

.selector-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  background: #f5f5f5;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.selector-item.active {
  background: #fff;
  border: 4rpx solid #D32F2F;
  box-shadow: 0 4rpx 16rpx rgba(211, 47, 47, 0.2);
}

.selector-item .item-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.selector-item .item-name {
  font-size: 26rpx;
  color: #666;
}

.selector-item.active .item-name {
  color: #D32F2F;
  font-weight: 600;
}

/* 添加按钮样式 */
.selector-item.add-btn {
  background: #fff;
  border: 2rpx dashed #ccc;
}

.selector-item.add-btn .item-icon,
.selector-item.add-btn .item-name {
  color: #999;
}

.selector-item.add-btn:active {
  background: #f5f5f5;
  border-color: #D32F2F;
}

.selector-item.add-btn:active .item-icon,
.selector-item.add-btn:active .item-name {
  color: #D32F2F;
}

/* 弹窗遮罩 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.popup-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 弹窗内容 */
.popup-content {
  width: 100%;
  max-width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  transform: scale(0.9) translateY(20rpx);
  opacity: 0;
  transition: all 0.3s ease;
  overflow: hidden;
}

.popup-content.show {
  transform: scale(1) translateY(0);
  opacity: 1;
}

/* 弹窗头部 */
.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
  border-radius: 50%;
  transition: all 0.2s;
}

.popup-close:active {
  background: #f5f5f5;
  color: #666;
}

/* 弹窗主体 */
.popup-body {
  padding: 20rpx 32rpx 32rpx;
}

.popup-input {
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx;
  background: #f8f8f8;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.popup-input:focus {
  background: #fff;
  border-color: #D32F2F;
}

.popup-hint {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

/* 弹窗底部按钮 */
.popup-footer {
  display: flex;
  padding: 0 32rpx 32rpx;
  gap: 20rpx;
}

.popup-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  transition: all 0.2s;
}

.popup-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.popup-btn.cancel:active {
  background: #e8e8e8;
}

.popup-btn.confirm {
  background: linear-gradient(135deg, #D32F2F, #FF6B6B);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(211, 47, 47, 0.3);
}

.popup-btn.confirm:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(211, 47, 47, 0.2);
}

/* 结果卡片特殊样式 */
.result-card {
  background: linear-gradient(135deg, #fff9f9, #ffffff);
  border: 2rpx solid rgba(211, 47, 47, 0.15);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-top: 30rpx;
  position: relative;
}

.result-card::before {
  content: '"';
  position: absolute;
  top: 20rpx;
  left: 30rpx;
  font-size: 60rpx;
  color: rgba(211, 47, 47, 0.2);
  font-family: Georgia, serif;
}

.result-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  padding-left: 20rpx;
}

/* 加载动画 */
.loading-small {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 免费次数用完提示卡片 - 仿登录特权风格 */
.limit-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 30rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.limit-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.limit-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.limit-item::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 2rpx;
  background: #f5f5f5;
}

.limit-item.last-item::before {
  display: none;
}

.limit-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  width: 40rpx;
}

.limit-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.limit-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.limit-desc {
  font-size: 24rpx;
  color: #999;
}

.limit-btn {
  width: 100% !important;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding: 0;
  height: 88rpx;
  background: linear-gradient(135deg, #D32F2F, #FF6B6B);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(211, 47, 47, 0.3);
  line-height: 1;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.limit-btn.invite {
  background: linear-gradient(135deg, #07C160, #10B981);
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.limit-btn::after {
  border: none;
}

.limit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(211, 47, 47, 0.2);
}

.limit-btn.invite:active {
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.2);
}

/* 使用次数提示 */
.usage-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.invite-count {
  color: #43A047;
  font-weight: 500;
}

